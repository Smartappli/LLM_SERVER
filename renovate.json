{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "🤖 Dependencies"
  ],
  "timezone": "Etc/UTC",
  "schedule": [
    "after 1:00am and before 6:00am on monday"
  ],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10,
  "rebaseWhen": "behind-base-branch",
  "separateMajorMinor": true,
  "enabledManagers": [
    "dockerfile",
    "github-actions",
    "pip_requirements"
  ],
  "dockerfile": {
    "fileMatch": [
      "(^|/).*\\.Dockerfile$"
    ]
  },
  "pip_requirements": {
    "fileMatch": [
      "(^|/)requirements(-[^/]+)?\\.txt$"
    ]
  },
  "packageRules": [
    {
      "matchManagers": [
        "dockerfile"
      ],
      "groupName": "docker base images"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github actions"
    }
  ]
}
